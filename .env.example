# Copy to .env for local development (never commit .env)
# On AWS, set these as environment variables in your deployment target (EB, ECS, EC2, etc.)

SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=leave_management_db
DB_USERNAME=root
DB_PASSWORD=your_local_mysql_password

# JWT (64-character hex string recommended for HS256)
JWT_SECRET=your_64_character_hex_jwt_secret_here_replace_before_any_shared_deployment

# Optional production overrides
# SERVER_PORT=8080
# JWT_EXPIRATION=86400000
